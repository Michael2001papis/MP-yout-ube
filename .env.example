VITE_FIREBASE_API_KEY="YOUR_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_AUTH_DOMAIN"
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_STORAGE_BUCKET"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_APP_ID"

# Comma-separated list of emails that receive `admin` role when the user document is created (first sign-in).
# The first email is treated as the "primary" admin slot in UI copy. List order matters for that label only.
VITE_ADMIN_EMAILS="admin@example.com"

# Public display name for the primary administrator (e.g. MIKI). Shown in the admin dashboard — not a password or secret.
VITE_ADMIN_DISPLAY_NAME="MIKI"

# Google Sign-In (same Firebase web app as above):
# 1) Firebase Console → Authentication → Sign-in method → enable "Google".
# 2) Authentication → Settings → Authorized domains: include localhost (dev) and your production domain.

